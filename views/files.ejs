<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CloudClone — My Files</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
</head>
<body class="min-h-screen bg-slate-950 font-[IBM_Plex_Sans] flex flex-col items-center px-4 py-16">

  <!-- Header -->
  <header class="w-full max-w-2xl mb-10">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
        <span class="font-[IBM_Plex_Mono] text-zinc-600 text-xs tracking-widest uppercase">My Files</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-zinc-400 text-sm">Hello, <span class="text-blue-400 font-medium"><%= username %></span></span>
        <a href="/files/upload" class="font-[IBM_Plex_Mono] text-xs text-zinc-400 hover:text-blue-400 transition-colors uppercase tracking-widest">Upload</a>
        <a href="/user/logout" class="font-[IBM_Plex_Mono] text-xs text-zinc-400 hover:text-red-400 transition-colors uppercase tracking-widest">Logout</a>
      </div>
    </div>
    <h1 class="font-[IBM_Plex_Mono] text-3xl font-semibold text-white tracking-tight">
      Your <span class="text-blue-500">Files</span>
    </h1>
    <p class="text-zinc-600 text-sm mt-2 font-light"><%= files.length %> file(s) stored in the cloud.</p>
  </header>

  <!-- Upload link -->
  <div class="w-full max-w-2xl mb-6">
    <a href="/files"
      class="inline-flex items-center gap-2 font-[IBM_Plex_Mono] text-xs text-zinc-400 hover:text-blue-400 transition-colors uppercase tracking-widest"
    >
      ← Back to upload
    </a>
  </div>

  <!-- File List -->
  <section class="w-full max-w-2xl flex flex-col gap-3">

    <% if (files.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-16 h-16 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
        </div>
        <p class="text-zinc-600 font-[IBM_Plex_Mono] text-sm">No files uploaded yet.</p>
        <a href="/files" class="mt-4 text-blue-500 hover:text-blue-400 font-[IBM_Plex_Mono] text-xs transition-colors">Upload your first file →</a>
      </div>
    <% } %>

    <% files.forEach(file => { %>
      <%
        const ext = file.filetype ? file.filetype.split('/').pop().toUpperCase() : 'FILE';
        const colorMap = {
          'PDF': 'bg-red-600', 'PNG': 'bg-violet-600', 'JPEG': 'bg-violet-600',
          'JPG': 'bg-violet-600', 'MP4': 'bg-pink-600', 'ZIP': 'bg-yellow-600',
          'DOCX': 'bg-blue-700', 'TXT': 'bg-green-700'
        };
        const color = colorMap[ext] || 'bg-slate-600';
        const sizeKB = file.size ? (file.size / 1024).toFixed(1) + ' KB' : 'Unknown size';
      %>
      <div class="flex items-center gap-4 bg-slate-900 border border-slate-800 rounded-xl px-4 py-3.5">
        <div class="w-11 h-11 rounded-lg <%= color %> flex items-center justify-center flex-shrink-0">
          <span class="font-[IBM_Plex_Mono] text-[10px] font-semibold text-white"><%= ext.substring(0,4) %></span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-white text-sm font-medium truncate"><%= file.filename %></p>
          <p class="text-zinc-600 text-xs mt-0.5 font-[IBM_Plex_Mono]"><%= sizeKB %> &nbsp;·&nbsp; <%= new Date(file.createdAt).toLocaleDateString() %></p>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <a href="<%= file.url %>" target="_blank"
            class="w-7 h-7 rounded-lg bg-slate-800 hover:bg-blue-600 flex items-center justify-center transition-colors duration-150"
            title="Download"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
          </a>
          <form action="/files/delete/<%= file._id %>" method="POST" onsubmit="return confirm('Delete this file?')">
            <button type="submit"
              class="w-7 h-7 rounded-lg bg-slate-800 hover:bg-red-600 flex items-center justify-center transition-colors duration-150"
              title="Delete"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    <% }) %>

  </section>

  <!-- Footer -->
  <footer class="w-full max-w-2xl mt-12 pt-5 border-t border-slate-800 flex items-center justify-between">
    <p class="font-[IBM_Plex_Mono] text-zinc-600 text-xs">CloudClone v1.0</p>
    <div class="flex items-center gap-1.5">
      <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
      <span class="font-[IBM_Plex_Mono] text-zinc-600 text-xs">Ready</span>
    </div>
  </footer>

</body>
</html>
