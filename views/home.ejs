<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>CloudClone — Home</title>
  </head>
  <body>
    <div class="flex flex-col min-h-screen w-full bg-slate-950">

      <!-- Navbar -->
      <nav class="bg-gray-800 p-4 sticky top-0 z-50">
        <div class="container mx-auto flex items-center justify-between">
          <a href="/home" class="text-white text-lg font-semibold flex flex-row items-center justify-center">
            <img src="/logo.png" height="10" width="30" /> &nbsp; Cloud Clone
          </a>
          <div class="flex items-center gap-1">
            <a href="/user/register" class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Register</a>
            <a href="/user/login" class="text-gray-300 hover:text-white px-3 py-2 rounded-md text-sm font-medium">Login</a>
          </div>
        </div>
      </nav>

      <!-- Hero Section -->
      <div class="flex flex-col items-center justify-center flex-1 w-full gap-6 px-4 py-16 sm:py-24 text-center">

        <p class="bg-slate-900 rounded-full border border-blue-500 text-blue-500 px-4 py-2 text-sm sm:text-base mb-4 sm:mb-10">
          Introducing Cloud Clone — Now with AI search
        </p>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-white font-bold leading-tight">
          Your files.<br>Always with you,<br>
          <span class="text-blue-500">everywhere.</span>
        </h1>

        <p class="text-zinc-500 text-base sm:text-lg md:text-xl max-w-xl">
          Store, share, and collaborate on any file — from any device.<br class="hidden sm:block">
          Blazing fast, beautifully simple, completely secure.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-3 mt-2">
          <button
            class="w-full sm:w-auto text-black bg-gray-200 hover:bg-gray-300 shadow-xs font-medium rounded-xl text-sm px-6 py-2.5 focus:outline-none transition-colors"
            onclick="window.location.href='/user/register'">
            Register
          </button>
          <button
            class="w-full sm:w-auto text-black bg-gray-200 hover:bg-gray-300 shadow-xs font-medium rounded-xl text-sm px-6 py-2.5 focus:outline-none transition-colors"
            onclick="window.location.href='/user/login'">
            Login
          </button>
        </div>

      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.js"></script>
  </body>
</html>
