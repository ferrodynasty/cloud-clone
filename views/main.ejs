<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CloudClone — Upload</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
</head>
<body class="min-h-screen bg-slate-950 font-[IBM_Plex_Sans] flex flex-col items-center px-4 py-16">

  <!-- Header -->
  <header class="w-full max-w-2xl mb-10">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
        <span class="font-[IBM_Plex_Mono] text-zinc-600 text-xs tracking-widest uppercase">File Manager</span>
      </div>
      <div class="flex items-center gap-4">
        <span class="text-zinc-400 text-sm">Hello, <span class="text-blue-400 font-medium"><%= username %></span></span>
        <a href="/files" class="font-[IBM_Plex_Mono] text-xs text-zinc-400 hover:text-blue-400 transition-colors uppercase tracking-widest">My Files</a>
        <a href="/user/logout" class="font-[IBM_Plex_Mono] text-xs text-zinc-400 hover:text-red-400 transition-colors uppercase tracking-widest">Logout</a>
      </div>
    </div>
    <h1 class="font-[IBM_Plex_Mono] text-3xl font-semibold text-white tracking-tight">
      Upload <span class="text-blue-500">Files</span>
    </h1>
    <p class="text-zinc-600 text-sm mt-2 font-light">Drag and drop or browse to upload your files.</p>
  </header>

  <!-- Upload Form -->
  <form action="/files/upload" method="POST" enctype="multipart/form-data" class="w-full max-w-2xl">

    <label
      for="file-input"
      class="rounded-xl border border-dashed border-blue-500 bg-slate-950 cursor-pointer flex flex-col items-center justify-center gap-6 py-24 px-8 text-center hover:bg-slate-900 transition-colors duration-150 block"
    >
      <div class="w-16 h-16 rounded-xl bg-slate-900 border border-slate-800 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
        </svg>
      </div>
      <div>
        <p class="text-white font-medium text-base">Drag &amp; drop files here</p>
        <p class="text-zinc-600 text-sm mt-1">
          or <span class="text-blue-500 underline underline-offset-2">browse from your device</span>
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-2">
        <span class="font-[IBM_Plex_Mono] text-xs text-zinc-600 border border-slate-800 rounded-full px-3 py-0.5">PDF</span>
        <span class="font-[IBM_Plex_Mono] text-xs text-zinc-600 border border-slate-800 rounded-full px-3 py-0.5">PNG</span>
        <span class="font-[IBM_Plex_Mono] text-xs text-zinc-600 border border-slate-800 rounded-full px-3 py-0.5">JPG</span>
        <span class="font-[IBM_Plex_Mono] text-xs text-zinc-600 border border-slate-800 rounded-full px-3 py-0.5">MP4</span>
        <span class="font-[IBM_Plex_Mono] text-xs text-zinc-600 border border-slate-800 rounded-full px-3 py-0.5">ZIP</span>
        <span class="font-[IBM_Plex_Mono] text-xs text-zinc-600 border border-slate-800 rounded-full px-3 py-0.5">DOCX</span>
      </div>
      <!-- FIXED: name="file" to match upload.single('file') -->
      <input id="file-input" type="file" name="file" class="hidden"/>
    </label>

    <button type="submit"
      class="mt-4 w-full py-3.5 rounded-xl bg-blue-500 hover:bg-blue-400 transition-colors duration-150 text-black font-[IBM_Plex_Mono] font-semibold text-sm tracking-widest uppercase flex items-center justify-center cursor-pointer"
    >
      Upload File
    </button>

  </form>

  <!-- Go to My Files -->
  <div class="w-full max-w-2xl mt-8 text-center">
    <a href="/files" class="font-[IBM_Plex_Mono] text-sm text-blue-500 hover:text-blue-400 transition-colors">
      → View all uploaded files
    </a>
  </div>

  <!-- Footer -->
  <footer class="w-full max-w-2xl mt-12 pt-5 border-t border-slate-800 flex items-center justify-between">
    <p class="font-[IBM_Plex_Mono] text-zinc-600 text-xs">CloudClone v1.0</p>
    <div class="flex items-center gap-1.5">
      <div class="w-1.5 h-1.5 rounded-full bg-blue-500"></div>
      <span class="font-[IBM_Plex_Mono] text-zinc-600 text-xs">Ready</span>
    </div>
  </footer>

</body>
</html>
